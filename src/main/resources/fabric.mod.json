{
	"schemaVersion": 1,
	"id": "e33chat",
	"version": "${version}",
	"name": "E33EPUS's ChatScreen",
	"description": "A simple mod that replaces the vanilla chat screen for Minecraft",
	"authors": [
		"E33EPUS"
	],
	"license": "MIT",
	"icon": "icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"com.niuqu.chatbubble.E33chatMod"
		],
		"client": [
			"com.niuqu.chatbubble.client.E33chatClient"
		]
	},
	"mixins": [
		"e33chat.mixins.json",
		"e33chat.client.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.15.0",
		"minecraft": "~1.20.1",
		"java": ">=17",
		"fabric-api": "*"
	},
	"recommends": {
		"modmenu": "*"
	},
	"custom": {
		"modmenu": {
			"name": "E33EPUS's ChatScreen",
			"links": {
				"modmenu.github_releases": "https://github.com/E33EPUS/E33EPUS-s-ChatScreen"
			}
		}
	}
}
